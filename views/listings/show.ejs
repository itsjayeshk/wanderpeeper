<% layout("/layouts/boilerplate") %>
<%
    const listingImageUrl =
        listing.image &&
        listing.image.url &&
        !listing.image.url.startsWith("/uploads/")
            ? listing.image.url
            : "https://images.unsplash.com/photo-1506744038136-46273834b3fb";
%>

<style>
    .listing-container {
        margin-top: 2rem;
        margin-bottom: 4rem;
    }

    .show-card {
        border: none;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
    }

    .show-img {
        height: 450px;
        object-fit: cover;
    }

    .listing-info p {
        margin-bottom: 0.7rem;
        font-size: 1.05rem;
    }

    .owner-text {
        font-weight: 600;
        color: #444;
    }

    .price-tag {
        font-size: 1.4rem;
        font-weight: 700;
        color: #198754;
    }

    .action-btns {
        gap: 12px;
    }

    .review-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 18px rgba(0,0,0,0.06);
        transition: 0.3s ease;
    }

    .review-card:hover {
        transform: translateY(-3px);
    }

    .review-comment {
        color: #555;
        line-height: 1.6;
    }

    textarea.form-control {
        resize: none;
    }

    .section-title {
        font-weight: 700;
        margin-bottom: 1rem;
    }

    .location-text {
        color: #666;
    }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    @media(max-width: 768px) {
        .show-img {
            height: 280px;
        }

        .review-card {
            width: 100%;
        }
    }
</style>

<div class="container listing-container">

    <!-- TITLE -->
    <div class="row mb-3">
        <div class="col-lg-8 offset-lg-2">
            <h2 class="fw-bold">
                <%= listing.title %>
            </h2>
        </div>
    </div>

    <!-- MAIN CARD -->
    <div class="row">
        <div class="col-lg-8 offset-lg-2">

            <div class="card show-card">

                <!-- IMAGE -->
                <img
                    src="<%= listingImageUrl %>"
                    class="card-img-top show-img"
                    alt="listing-image"
                >

                <!-- BODY -->
                <div class="card-body p-4">

                    <div class="listing-info">

                        <p class="owner-text">
                            Hosted by @<%= listing.owner.username %>
                        </p>

                        <p>
                            <%= listing.description %>
                        </p>

                        <p class="price-tag">
                            ₹ <%= listing.price.toLocaleString("en-IN") %>
                        </p>

                        <p class="location-text">
                            <i class="fa-solid fa-location-dot"></i>
                            <%= listing.location %>,
                            <%= listing.country %>
                        </p>

                    </div>

                </div>

            </div>

        </div>
    </div>

    <!-- EDIT + DELETE -->
    <% if(currUser && currUser._id.equals(listing.owner._id)) { %>

        <div class="row mt-4">
            <div class="col-lg-8 offset-lg-2 d-flex action-btns">

                <a
                    href="/listings/<%= listing._id %>/edit"
                    class="btn btn-dark px-4"
                >
                    <i class="fa-solid fa-pen"></i>
                    Edit
                </a>

                <form
                    method="POST"
                    action="/listings/<%= listing._id %>?_method=DELETE"
                >

                    <button class="btn btn-danger px-4">
                        <i class="fa-solid fa-trash"></i>
                        Delete
                    </button>

                </form>

            </div>
        </div>

    <% } %>

    <!-- REVIEW FORM -->
    <% if(currUser) { %>

        <div class="row mt-5">
            <div class="col-lg-8 offset-lg-2">

                <hr class="mb-4">

                <h4 class="section-title">
                    Leave a Review
                </h4>

                <form
                    method="POST"
                    action="/listings/<%= listing._id %>/reviews"
                    class="needs-validation"
                    novalidate
                >

                    <!-- STAR RATING -->
                    <div class="mb-4">

                        <label class="form-label fw-semibold mb-2">
                            Rating
                        </label>

                        <fieldset class="starability-slot">

                            <input
                                type="radio"
                                id="no-rate"
                                class="input-no-rate"
                                name="review[rating]"
                                value="0"
                                checked
                                aria-label="No rating."
                            />

                            <input type="radio" id="rate1" name="review[rating]" value="1" />
                            <label for="rate1" title="Terrible">1 star</label>

                            <input type="radio" id="rate2" name="review[rating]" value="2" />
                            <label for="rate2" title="Not good">2 stars</label>

                            <input type="radio" id="rate3" name="review[rating]" value="3" />
                            <label for="rate3" title="Average">3 stars</label>

                            <input type="radio" id="rate4" name="review[rating]" value="4" />
                            <label for="rate4" title="Very good">4 stars</label>

                            <input type="radio" id="rate5" name="review[rating]" value="5" />
                            <label for="rate5" title="Amazing">5 stars</label>

                        </fieldset>

                    </div>

                    <!-- COMMENT -->
                    <div class="mb-4">

                        <label
                            for="comment"
                            class="form-label fw-semibold"
                        >
                            Comment
                        </label>

                        <textarea
                            name="review[comment]"
                            id="comment"
                            rows="4"
                            class="form-control"
                            placeholder="Share your experience..."
                            required
                        ></textarea>

                        <div class="invalid-feedback">
                            Please enter a review comment.
                        </div>

                    </div>

                    <button class="btn btn-success px-4">
                        Submit Review
                    </button>

                </form>

            </div>
        </div>

    <% } %>

    <!-- REVIEWS -->
    <div class="row mt-5">

        <div class="col-lg-8 offset-lg-2">

            <hr class="mb-4">

            <h4 class="section-title">
                User Reviews
            </h4>

            <div class="row">

                <% if(listing.reviews.length === 0) { %>

                    <p class="text-muted">
                        No reviews yet.
                    </p>

                <% } %>

                <% for(let review of listing.reviews) { %>

                    <div class="col-md-6 mb-4">

                        <div class="card review-card h-100">

                            <div class="card-body">

                                <div class="review-header mb-3">

                                    <small class="text-muted">

                                        <% if(review.author) { %>

                                            @<%= review.author.username %>

                                        <% } else { %>

                                            @Anonymous

                                        <% } %>

                                    </small>

                                    <p
                                        class="starability-result m-0"
                                        data-rating="<%= review.rating %>"
                                    >
                                        Rated:
                                        <%= review.rating %>
                                        stars
                                    </p>

                                </div>

                                <p class="review-comment">
                                    <%= review.comment %>
                                </p>

                            </div>

                            <!-- DELETE REVIEW -->
                            <% if(review.author && currUser && review.author._id.equals(currUser._id)) { %>

                                <div class="card-footer bg-white border-0">

                                    <form
                                        method="POST"
                                        action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                    >

                                        <button class="btn btn-outline-danger btn-sm">
                                            Delete Review
                                        </button>

                                    </form>

                                </div>

                            <% } %>

                        </div>

                    </div>

                <% } %>

            </div>

        </div>

    </div>

</div>

<!-- Bootstrap Validation -->
<script>
    (() => {
        'use strict';

        const forms = document.querySelectorAll('.needs-validation');

        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {

                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();
                }

                form.classList.add('was-validated');

            }, false);
        });
    })();
</script>
